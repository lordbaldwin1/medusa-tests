#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../node_modules/pnpm/bin/pnpx.cjs" "$@"
else
  exec node  "$basedir/../node_modules/pnpm/bin/pnpx.cjs" "$@"
fi
# cmd-shim-target=/Users/zach/workspace/dtc-starter/.pnpm-store/v11/links/@/pnpm/10.11.1/86cdc253ee22f10c8ba7f190be0b795a45cb260652788343470dd6a366a30d96/node_modules/pnpm/bin/pnpx.cjs
