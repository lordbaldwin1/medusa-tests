{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node", "@playwright/test"],
    "baseUrl": ".",
    "paths": {
      "@playwright/*": ["playwright/*"]
    }
  },
  "include": ["playwright/**/*.ts", "playwright.config.ts"]
}
